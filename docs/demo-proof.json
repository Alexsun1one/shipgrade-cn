    "accepted=$TMP/shipgrade-demo-project-ytgrdi1n/accepted-handoff.md: ship-grade-ok",
    "next=open $TMP/shipgrade-demo-project-ytgrdi1n/.shipgrade/task-brief.md",
    "cleaned=true"
  ]
}
